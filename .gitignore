# =============================================================================
# UrbanPulse .gitignore
# =============================================================================

# --- Environment & Secrets (NEVER commit these) ---
.env
*.env
.env.*
!.env.example
profiles.yml              # dbt Snowflake credentials

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
.venv/
venv/
env/

# --- Airflow ---
airflow/logs/
airflow/plugins/__pycache__/
airflow.db
airflow.cfg
standalone_admin_password.txt
webserver_config.py

# --- dbt ---
dbt/urbanpulse/target/
dbt/urbanpulse/dbt_packages/
dbt/urbanpulse/logs/

# --- Docker ---
docker/volumes/

# --- Airbyte ---
airbyte/.secrets/

# --- Streamlit ---
.streamlit/secrets.toml

# --- macOS ---
.DS_Store
.AppleDouble

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Misc ---
*.log
*.tmp
*.bak
